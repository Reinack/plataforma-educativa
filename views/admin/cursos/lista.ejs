<div class="d-flex justify-content-between mb-3">
  <h2><i class="bi bi-collection-play"></i> Cursos</h2>
  <a href="/admin/cursos/nuevo" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nuevo curso</a>
</div>
<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light"><tr><th>Título</th><th>Categoría</th><th>Instructor</th><th>Módulos</th><th>Asignados</th><th>Estado</th><th></th></tr></thead>
      <tbody>
        <% cursos.forEach(c => { %>
          <tr>
            <td><a href="/admin/cursos/<%= c.id %>" class="text-decoration-none text-reset"><strong><%= c.titulo %></strong></a></td>
            <td><%= c.categoria || '—' %></td>
            <td><%= c.instructor || '—' %></td>
            <td><%= c.num_modulos %></td>
            <td><%= c.inscriptos %></td>
            <td><span class="badge bg-<%= c.publicado ? 'success' : 'secondary' %>"><%= c.publicado ? 'Publicado' : 'Borrador' %></span></td>
            <td class="tabla-acciones">
              <a href="/admin/cursos/<%= c.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
              <form action="/admin/cursos/<%= c.id %>/eliminar" method="POST" class="d-inline" onsubmit="return confirm('¿Eliminar curso? También se borrarán módulos y lecciones.')">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
