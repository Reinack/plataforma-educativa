<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h2 class="mb-1"><i class="bi bi-people"></i> Usuarios</h2>
    <p class="text-muted mb-0">Gestión de todas las cuentas de la plataforma.</p>
  </div>
  <a href="/admin/usuarios/nuevo" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nuevo usuario</a>
</div>

<!-- Filtros rápidos por rol (tarjetas clickeables) -->
<div class="row g-3 mb-3">
  <div class="col-lg col-md-4 col-6">
    <a href="/admin/usuarios" class="text-decoration-none">
      <div class="card filtro-rol <%= !rol ? 'filtro-rol-activo' : '' %>">
        <div class="card-body py-3 d-flex align-items-center justify-content-between">
          <div>
            <div class="text-muted small">Total</div>
            <div class="fs-4 fw-bold text-light"><%= conteoPorRol.admin + conteoPorRol.profesor + conteoPorRol.soporte + conteoPorRol.alumno %></div>
          </div>
          <i class="bi bi-people fs-2 text-muted"></i>
        </div>
      </div>
    </a>
  </div>
  <div class="col-lg col-md-4 col-6">
    <a href="/admin/usuarios?rol=admin" class="text-decoration-none">
      <div class="card filtro-rol filtro-admin <%= rol === 'admin' ? 'filtro-rol-activo' : '' %>">
        <div class="card-body py-3 d-flex align-items-center justify-content-between">
          <div>
            <div class="text-muted small">Administradores</div>
            <div class="fs-4 fw-bold" style="color:#fca5a5;"><%= conteoPorRol.admin %></div>
          </div>
          <i class="bi bi-shield-lock fs-2" style="color:#fca5a5; opacity:.5;"></i>
        </div>
      </div>
    </a>
  </div>
  <div class="col-lg col-md-4 col-6">
    <a href="/admin/usuarios?rol=profesor" class="text-decoration-none">
      <div class="card filtro-rol filtro-profesor <%= rol === 'profesor' ? 'filtro-rol-activo' : '' %>">
        <div class="card-body py-3 d-flex align-items-center justify-content-between">
          <div>
            <div class="text-muted small">Profesores</div>
            <div class="fs-4 fw-bold" style="color:#c4b5fd;"><%= conteoPorRol.profesor %></div>
          </div>
          <i class="bi bi-mortarboard fs-2" style="color:#c4b5fd; opacity:.5;"></i>
        </div>
      </div>
    </a>
  </div>
  <div class="col-lg col-md-4 col-6">
    <a href="/admin/usuarios?rol=soporte" class="text-decoration-none">
      <div class="card filtro-rol filtro-soporte <%= rol === 'soporte' ? 'filtro-rol-activo' : '' %>">
        <div class="card-body py-3 d-flex align-items-center justify-content-between">
          <div>
            <div class="text-muted small">Soporte</div>
            <div class="fs-4 fw-bold" style="color:#7dd3fc;"><%= conteoPorRol.soporte %></div>
          </div>
          <i class="bi bi-headset fs-2" style="color:#7dd3fc; opacity:.5;"></i>
        </div>
      </div>
    </a>
  </div>
  <div class="col-lg col-md-4 col-6">
    <a href="/admin/usuarios?rol=alumno" class="text-decoration-none">
      <div class="card filtro-rol filtro-alumno <%= rol === 'alumno' ? 'filtro-rol-activo' : '' %>">
        <div class="card-body py-3 d-flex align-items-center justify-content-between">
          <div>
            <div class="text-muted small">Alumnos</div>
            <div class="fs-4 fw-bold" style="color:#6ee7b7;"><%= conteoPorRol.alumno %></div>
          </div>
          <i class="bi bi-person-fill fs-2" style="color:#6ee7b7; opacity:.5;"></i>
        </div>
      </div>
    </a>
  </div>
</div>

<!-- Buscador + filtro alumnos -->
<form class="card card-body mb-3 py-2" method="GET">
  <div class="row g-2 align-items-center">
    <div class="col-md-7">
      <div class="input-group">
        <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search"></i></span>
        <input type="text" name="q" value="<%= q || '' %>" class="form-control border-start-0 ps-0" placeholder="Buscar por nombre o usuario...">
      </div>
    </div>
    <div class="col-md-3">
      <select name="rol" class="form-select">
        <option value="">Todos los roles</option>
        <option value="admin" <%= rol === 'admin' ? 'selected' : '' %>>Administradores</option>
        <option value="profesor" <%= rol === 'profesor' ? 'selected' : '' %>>Profesores</option>
        <option value="soporte" <%= rol === 'soporte' ? 'selected' : '' %>>Soporte</option>
        <option value="alumno" <%= rol === 'alumno' ? 'selected' : '' %>>Alumnos (<%= conteoPorRol.alumno %>)</option>
      </select>
    </div>
    <div class="col-md-2 d-grid"><button class="btn btn-primary"><i class="bi bi-funnel"></i> Filtrar</button></div>
  </div>
</form>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>Usuario</th><th>Acceso</th><th>Rol</th><th>Estado</th><th>Creado</th><th class="tabla-acciones text-end pe-3">Acciones</th></tr>
      </thead>
      <tbody>
        <% if (usuarios.length === 0) { %>
          <tr><td colspan="6" class="text-center py-4 text-muted"><i class="bi bi-search"></i> Sin resultados con esos filtros.</td></tr>
        <% } %>
        <% usuarios.forEach(u => { %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <% if (u.avatar) { %>
                  <img src="<%= u.avatar %>" alt="" class="avatar-circle avatar-rol-<%= u.rol %>" style="object-fit: cover;">
                <% } else { %>
                  <div class="avatar-circle avatar-rol-<%= u.rol %>"><%= u.nombre.charAt(0).toUpperCase() %></div>
                <% } %>
                <strong><%= u.nombre %></strong>
              </div>
            </td>
            <td><code><%= u.username %></code></td>
            <td>
              <span class="rol-tag rol-tag-<%= u.rol %>">
                <% if (u.rol === 'admin') { %><i class="bi bi-shield-lock-fill"></i> Administrador
                <% } else if (u.rol === 'profesor') { %><i class="bi bi-mortarboard-fill"></i> Profesor
                <% } else if (u.rol === 'soporte') { %><i class="bi bi-headset"></i> Soporte
                <% } else { %><i class="bi bi-person-fill"></i> Alumno
                <% } %>
              </span>
            </td>
            <td>
              <% if (u.activo) { %>
                <span class="status-dot status-on"></span> <span class="small">Activo</span>
              <% } else { %>
                <span class="status-dot status-off"></span> <span class="small text-muted">Inactivo</span>
              <% } %>
            </td>
            <td class="small text-muted"><%= helpers.formatDateShort(u.fecha_creacion) %></td>
            <td class="tabla-acciones text-end pe-3">
              <a href="/admin/usuarios/<%= u.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
              <% if (u.id !== currentUser.id) { %>
                <form action="/admin/usuarios/<%= u.id %>/eliminar" method="POST" class="d-inline" onsubmit="return confirm('¿Eliminar usuario?')">
                  <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div class="card-footer text-muted small">
    Mostrando <strong><%= usuarios.length %></strong> usuario<%= usuarios.length === 1 ? '' : 's' %><% if (q || rol) { %> · <a href="/admin/usuarios">Limpiar filtros</a><% } %>
  </div>
</div>
