<h2><i class="bi bi-bar-chart"></i> Estadísticas</h2>

<div class="row g-3 mt-1">
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header bg-white"><strong>Cursos más populares</strong></div>
      <div class="table-responsive">
        <table class="table mb-0">
          <thead class="table-light"><tr><th>Curso</th><th>Inscriptos</th><th>Lecciones vistas</th></tr></thead>
          <tbody>
            <% cursosPop.forEach(c => { %>
              <tr><td><%= c.titulo %></td><td><%= c.inscriptos %></td><td><%= c.leccs_vistas %></td></tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header bg-white"><strong>Alumnos más activos</strong></div>
      <div class="table-responsive">
        <table class="table mb-0">
          <thead class="table-light"><tr><th>Alumno</th><th>Cursos</th><th>Lecciones</th></tr></thead>
          <tbody>
            <% alumnosActivos.forEach(a => { %>
              <tr><td><%= a.nombre %><div class="small text-muted">@<%= a.username %></div></td><td><%= a.cursos %></td><td><%= a.lecciones %></td></tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
