<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">¡Hola, <%= currentUser.nombre.split(' ')[0] %>! 👋</h2>
    <p class="text-muted mb-0">Esto es lo que pasa en tu plataforma hoy.</p>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-4 col-6">
    <div class="stat-card grad-indigo d-flex justify-content-between align-items-center">
      <div><div class="num"><%= stats.cursosInscritos %></div><div class="label">Cursos asignados</div></div>
      <div class="stat-icon"><i class="bi bi-collection-play"></i></div>
    </div>
  </div>
  <div class="col-md-4 col-6">
    <div class="stat-card grad-pink d-flex justify-content-between align-items-center">
      <div><div class="num"><%= stats.leccionesCompletadas %></div><div class="label">Videos vistos</div></div>
      <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
  <div class="col-md-4 col-6">
    <div class="stat-card grad-cyan d-flex justify-content-between align-items-center">
      <div><div class="num"><%= stats.proximasClases %></div><div class="label">Próximas clases</div></div>
      <div class="stat-icon"><i class="bi bi-camera-video"></i></div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-collection-play"></i> Mis cursos</h5>
        <a href="/cursos" class="btn btn-sm btn-outline-primary">Ver todos</a>
      </div>
      <div class="card-body">
        <% if (inscripciones.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-collection-play"></i>
            <p>Todavía no tenés cursos asignados.<br><small class="text-muted">El administrador te asignará cursos cuando estén listos.</small></p>
          </div>
        <% } else { %>
          <div class="row g-3">
            <% inscripciones.forEach(curso => {
              const pct = curso.total_lecciones ? Math.round(curso.completadas * 100 / curso.total_lecciones) : 0; %>
              <div class="col-md-6">
                <a href="/cursos/<%= curso.id %>" class="text-decoration-none text-reset">
                  <div class="card card-hover h-100">
                    <div class="curso-thumb"><i class="bi bi-play-circle"></i></div>
                    <div class="card-body">
                      <small class="text-muted"><%= curso.categoria || 'Sin categoría' %></small>
                      <h6 class="mt-1"><%= curso.titulo %></h6>
                      <div class="progress progress-thin mt-2"><div class="progress-bar" style="width: <%= pct %>%"></div></div>
                      <small class="text-muted"><%= curso.completadas %>/<%= curso.total_lecciones %> lecciones · <%= pct %>%</small>
                    </div>
                  </div>
                </a>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card mb-3">
      <div class="card-header bg-white"><h6 class="mb-0"><i class="bi bi-camera-video"></i> Próximas clases en vivo</h6></div>
      <div class="card-body p-0">
        <% if (proximasClases.length === 0) { %>
          <div class="empty-state py-3"><small>No hay clases programadas</small></div>
        <% } else { %>
          <ul class="list-group list-group-flush">
            <% proximasClases.forEach(c => { %>
              <li class="list-group-item">
                <a href="/clases/<%= c.id %>" class="text-decoration-none text-reset">
                  <strong><%= c.titulo %></strong>
                  <div class="small text-muted"><i class="bi bi-clock"></i> <%= helpers.formatDate(c.fecha_hora) %></div>
                </a>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>
    </div>
    <div class="card">
      <div class="card-header bg-white"><h6 class="mb-0"><i class="bi bi-chat-square-text"></i> Comunidad</h6></div>
      <div class="card-body p-0">
        <% if (ultimosPosts.length === 0) { %>
          <div class="empty-state py-3"><small>Sin publicaciones</small></div>
        <% } else { %>
          <ul class="list-group list-group-flush">
            <% ultimosPosts.forEach(p => { %>
              <li class="list-group-item">
                <a href="/comunidad/<%= p.id %>" class="text-decoration-none text-reset">
                  <strong><%= p.titulo %></strong>
                  <div class="small text-muted">Por <%= p.autor %> · <%= helpers.formatDateShort(p.fecha) %></div>
                </a>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>
    </div>
  </div>
</div>
