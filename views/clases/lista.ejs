<h2 class="mb-3"><i class="bi bi-camera-video"></i> Clases en vivo</h2>

<h5 class="mt-3 mb-2">Próximas</h5>
<% if (proximas.length === 0) { %>
  <div class="empty-state"><i class="bi bi-calendar-x"></i><p>No hay clases programadas.</p></div>
<% } else { %>
  <div class="row g-3 mb-4">
    <% proximas.forEach(c => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card card-hover h-100">
          <div class="card-body">
            <small class="text-uppercase text-primary fw-bold"><%= helpers.formatDate(c.fecha_hora) %></small>
            <h5 class="mt-1"><%= c.titulo %></h5>
            <p class="small text-muted"><%= c.descripcion ? c.descripcion.substring(0, 100) : '' %></p>
            <div class="small text-muted mb-2"><i class="bi bi-person"></i> <%= c.instructor || '—' %> · <%= c.duracion_min %> min</div>
            <% if (c.curso_titulo) { %><span class="badge bg-secondary mb-2"><%= c.curso_titulo %></span><% } %>
            <a href="/clases/<%= c.id %>" class="btn btn-primary btn-sm w-100">Ver detalles</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<h5 class="mt-4 mb-2">Pasadas</h5>
<% if (pasadas.length === 0) { %>
  <p class="text-muted small">Sin clases anteriores.</p>
<% } else { %>
  <div class="list-group">
    <% pasadas.forEach(c => { %>
      <a href="/clases/<%= c.id %>" class="list-group-item list-group-item-action d-flex justify-content-between">
        <div><strong><%= c.titulo %></strong><div class="small text-muted"><%= c.instructor || '—' %></div></div>
        <small class="text-muted"><%= helpers.formatDate(c.fecha_hora) %></small>
      </a>
    <% }) %>
  </div>
<% } %>

<link href='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css' rel='stylesheet' />

<h5 class="mt-5 mb-3 border-top pt-4">Calendario de Clases</h5>
<div id="calendar" class="mb-5"></div>

<script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js' defer></script>
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales/es.js' defer></script>
<style>
  #calendar {
    background: var(--bg-card);
    color: var(--text);
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    min-height: 640px;
    opacity: 0;
    transition: opacity .15s ease;
  }
  #calendar.fc-ready { opacity: 1; }
  .fc-theme-standard td, .fc-theme-standard th, .fc-theme-standard .fc-scrollgrid {
    border-color: var(--border) !important;
  }
  .fc-col-header-cell {
    background: var(--bg-elev-1);
  }
  .fc-event { cursor: pointer; border: none; }
  .fc .fc-button-primary { background-color: var(--primary); border-color: var(--primary); }
  .fc .fc-button-primary:hover { background-color: var(--primary-700); border-color: var(--primary-700); }
  .fc .fc-button-primary:not(:disabled).fc-button-active, .fc .fc-button-primary:not(:disabled):active { background-color: var(--primary-700); border-color: var(--primary-700); }
  .fc-daygrid-day-number { color: var(--text); text-decoration: none; font-weight: 500; }
  .fc-col-header-cell-cushion { color: var(--text-muted); text-decoration: none; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; }
  .fc-day-today { background-color: var(--bg-elev-2) !important; }
  .fc-day-other .fc-daygrid-day-number { color: var(--text-soft); }
</style>
<script>
  window.addEventListener('load', function() {
    var calendarEl = document.getElementById('calendar');

    var eventosProximas = <%- JSON.stringify(proximas.map(c => ({ title: c.titulo, start: c.fecha_hora, url: '/clases/' + c.id, color: '#4f46e5' }))) %>;
    var eventosPasadas = <%- JSON.stringify(pasadas.map(c => ({ title: c.titulo, start: c.fecha_hora, url: '/clases/' + c.id, color: '#94a3b8' }))) %>;

    var calendar = new FullCalendar.Calendar(calendarEl, {
      locale: 'es',
      initialView: 'dayGridMonth',
      headerToolbar: {
        left: 'prev,next today',
        center: 'title',
        right: 'dayGridMonth,timeGridWeek,listWeek'
      },
      events: eventosProximas.concat(eventosPasadas),
      eventClick: function(info) {
        if (info.event.url) {
          window.location.href = info.event.url;
          info.jsEvent.preventDefault();
        }
      }
    });

    calendar.render();
    calendarEl.classList.add('fc-ready');
  });
</script>
