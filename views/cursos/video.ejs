<nav aria-label="breadcrumb" class="small">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/cursos">Cursos</a></li>
    <li class="breadcrumb-item"><a href="/cursos/<%= cursoId %>"><%= video.curso_titulo %></a></li>
    <li class="breadcrumb-item active"><%= video.titulo %></li>
  </ol>
</nav>

<h3><%= video.titulo %></h3>
<p class="text-muted small"><%= video.modulo_titulo %></p>

<% if (video.descripcion) { %>
  <div class="card mb-3"><div class="card-body"><%= video.descripcion %></div></div>
<% } %>

<div class="video-wrapper mb-3">
  <% if (video.video_url) { %>
    <iframe src="<%= video.video_url %>" allowfullscreen allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"></iframe>
  <% } else if (video.video_path) { %>
    <video controls src="/<%= video.video_path %>"></video>
  <% } else { %>
    <div class="d-flex align-items-center justify-content-center h-100 text-white-50">
      <span><i class="bi bi-film"></i> Sin video</span>
    </div>
  <% } %>
</div>

<div class="d-flex justify-content-between align-items-center">
  <div>
    <% if (anterior) { %><a href="/cursos/<%= cursoId %>/videos/<%= anterior %>" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anterior</a><% } %>
  </div>
  <div>
    <% if (!completada) { %>
      <form action="/cursos/<%= cursoId %>/videos/<%= video.id %>/completar" method="POST" class="d-inline">
        <button class="btn btn-success"><i class="bi bi-check2"></i> Marcar como visto</button>
      </form>
    <% } else { %>
      <span class="badge bg-success p-2"><i class="bi bi-check-circle-fill"></i> Visto</span>
    <% } %>
  </div>
  <div>
    <% if (siguiente) { %><a href="/cursos/<%= cursoId %>/videos/<%= siguiente %>" class="btn btn-primary">Siguiente <i class="bi bi-arrow-right"></i></a><% } %>
  </div>
</div>
