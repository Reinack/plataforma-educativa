<h2><i class="bi bi-person-circle"></i> Mi perfil</h2>
<div class="row g-3 mt-1">
  <div class="col-md-4">
    <div class="card text-center">
      <div class="card-body">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" alt="Avatar" class="avatar-circle xl mx-auto" style="object-fit: cover; border: none;">
        <% } else { %>
          <div class="avatar-circle xl mx-auto"><%= user.nombre.charAt(0).toUpperCase() %></div>
        <% } %>
        <h5 class="mt-3"><%= user.nombre %></h5>
        <p class="small text-muted">@<%= user.username %></p>
        <span class="badge <%= user.rol === 'admin' ? 'badge-rol-admin' : 'badge-rol-alumno' %>"><%= user.rol %></span>
        <hr>
        <div class="row text-center">
          <div class="col"><strong><%= stats.cursos %></strong><div class="small text-muted">Cursos</div></div>
          <div class="col"><strong><%= stats.lecciones %></strong><div class="small text-muted">Lecciones</div></div>
          <div class="col"><strong><%= stats.posts %></strong><div class="small text-muted">Posts</div></div>
        </div>
        <small class="text-muted d-block mt-3">Miembro desde <%= helpers.formatDateShort(user.fecha_creacion) %></small>
      </div>
    </div>
  </div>
  <div class="col-md-8">
    <div class="card mb-3">
      <div class="card-header bg-white"><strong>Datos personales</strong></div>
      <form action="/perfil/actualizar" method="POST" enctype="multipart/form-data" class="card-body">
        <div class="mb-3">
          <label class="form-label">Foto de perfil (opcional)</label>
          <input type="file" name="avatar" class="form-control" accept="image/*">
        </div>
        <div class="mb-3"><label class="form-label">Nombre</label><input name="nombre" class="form-control" value="<%= user.nombre %>" required></div>
        <div class="mb-3"><label class="form-label">Usuario</label><input class="form-control" value="<%= user.username %>" disabled><small class="text-muted">El usuario lo asigna el administrador y no se puede cambiar.</small></div>
        <div class="mb-3"><label class="form-label">Bio</label><textarea name="bio" rows="3" class="form-control"><%= user.bio || '' %></textarea></div>
        <button class="btn btn-primary">Guardar cambios</button>
      </form>
    </div>
    <div class="card">
      <div class="card-header bg-white"><strong>Cambiar contraseña</strong></div>
      <form action="/perfil/password" method="POST" class="card-body">
        <div class="mb-3"><label class="form-label">Contraseña actual</label><input type="password" name="actual" class="form-control" required></div>
        <div class="row">
          <div class="col-md-6 mb-3"><label class="form-label">Nueva</label><input type="password" name="nueva" class="form-control" minlength="6" required></div>
          <div class="col-md-6 mb-3"><label class="form-label">Repetir nueva</label><input type="password" name="nueva2" class="form-control" minlength="6" required></div>
        </div>
        <button class="btn btn-warning">Actualizar contraseña</button>
      </form>
    </div>
  </div>
</div>
