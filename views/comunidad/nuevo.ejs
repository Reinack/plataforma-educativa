<h3><i class="bi bi-plus-lg"></i> Nuevo post</h3>
<form action="/comunidad/nuevo" method="POST" class="card card-body">
  <div class="mb-3">
    <label class="form-label">Comunidad</label>
    <select name="curso_id" class="form-select" required>
      <option value="general" <%= preCurso === 'general' || !preCurso ? 'selected' : '' %>>— General (visible a todos) —</option>
      <% cursos.forEach(c => { %>
        <option value="<%= c.id %>" <%= String(preCurso) === String(c.id) ? 'selected' : '' %>><%= c.titulo %></option>
      <% }) %>
    </select>
    <% if (cursos.length === 0 && currentUser.rol === 'alumno') { %>
      <small class="text-muted">Todavía no tenés cursos asignados; vas a publicar en General.</small>
    <% } else { %>
      <small class="text-muted">Elegí en qué comunidad publicar.</small>
    <% } %>
  </div>
  <div class="mb-3"><label class="form-label">Título</label><input name="titulo" class="form-control" required></div>
  <div class="mb-3"><label class="form-label">Contenido</label><textarea name="contenido" rows="8" class="form-control" required></textarea></div>
  <div><a href="/comunidad" class="btn btn-light">Cancelar</a> <button class="btn btn-primary">Publicar</button></div>
</form>
