<div class="mb-3">
  <h2 class="mb-1"><i class="bi bi-folder"></i> Material Descargable</h2>
  <p class="text-muted mb-0">PDFs, documentos, videos y recursos para descargar.</p>
</div>

<!-- Filtros rápidos por tipo (chips) -->
<div class="d-flex flex-wrap gap-2 mb-3">
  <a href="/material?<%= q ? 'q=' + encodeURIComponent(q) + '&' : '' %><%= curso_id ? 'curso_id=' + curso_id : '' %>" class="tipo-chip <%= !tipo ? 'active' : '' %>">
    <i class="bi bi-grid"></i> Todos
  </a>
  <% Object.keys(TIPO_META).forEach(t => {
       const meta = TIPO_META[t]; %>
    <a href="/material?<%= q ? 'q=' + encodeURIComponent(q) + '&' : '' %><%= curso_id ? 'curso_id=' + curso_id + '&' : '' %>tipo=<%= t %>"
       class="tipo-chip <%= tipo === t ? 'active' : '' %>"
       style="<%= tipo === t ? '--chip-color: ' + meta.color + ';' : '' %>">
      <i class="bi <%= meta.icon %>" style="color: <%= meta.color %>;"></i> <%= meta.label %>
    </a>
  <% }) %>
</div>

<!-- Buscador + filtro curso -->
<form class="card card-body mb-3 py-2" method="GET">
  <% if (tipo) { %><input type="hidden" name="tipo" value="<%= tipo %>"><% } %>
  <div class="row g-2 align-items-center">
    <div class="col-md-7">
      <div class="input-group">
        <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search"></i></span>
        <input type="text" name="q" value="<%= q || '' %>" class="form-control border-start-0 ps-0" placeholder="Buscar por título, descripción o nombre de archivo...">
      </div>
    </div>
    <div class="col-md-3">
      <select name="curso_id" class="form-select">
        <option value="">Todos los cursos</option>
        <option value="general" <%= curso_id === 'general' ? 'selected' : '' %>>— Material general —</option>
        <% cursos.forEach(c => { %>
          <option value="<%= c.id %>" <%= curso_id == c.id ? 'selected' : '' %>><%= c.titulo %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-2 d-grid"><button class="btn btn-primary"><i class="bi bi-funnel"></i> Filtrar</button></div>
  </div>
</form>

<% if (materiales.length === 0) { %>
  <div class="empty-state">
    <i class="bi bi-folder-x"></i>
    <p>No hay material con esos filtros.</p>
    <% if (q || curso_id || tipo) { %><a href="/material" class="btn btn-light btn-sm">Limpiar filtros</a><% } %>
  </div>
<% } else { %>
  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr><th>Archivo</th><th>Tipo</th><th>Curso</th><th>Tamaño</th><th>Subido</th><th></th></tr>
        </thead>
        <tbody>
          <% materiales.forEach(m => { %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="archivo-icono" style="background: <%= m.tipo_meta.color %>22; color: <%= m.tipo_meta.color %>;">
                    <i class="bi <%= m.tipo_meta.icon %>"></i>
                  </div>
                  <div>
                    <strong><%= m.titulo %></strong>
                    <% if (m.descripcion) { %><div class="small text-muted"><%= m.descripcion %></div><% } %>
                    <div class="small text-muted"><code><%= m.archivo_nombre %></code></div>
                  </div>
                </div>
              </td>
              <td>
                <span class="badge" style="background: <%= m.tipo_meta.color %>22; color: <%= m.tipo_meta.color %>; border: 1px solid <%= m.tipo_meta.color %>44;">
                  <%= m.tipo_meta.label %>
                </span>
              </td>
              <td>
                <% if (m.curso_titulo) { %>
                  <span class="badge bg-secondary"><%= m.curso_titulo %></span>
                <% } else { %>
                  <span class="text-muted small">— General —</span>
                <% } %>
              </td>
              <td class="small text-muted"><%= helpers.formatBytes(m.tamano_bytes) %></td>
              <td class="small text-muted"><%= helpers.formatDateShort(m.fecha) %></td>
              <td>
                <a href="/material/<%= m.id %>/descargar" class="btn btn-sm btn-primary">
                  <i class="bi bi-download"></i> Descargar
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="card-footer text-muted small">
      <strong><%= materiales.length %></strong> archivo<%= materiales.length === 1 ? '' : 's' %><% if (q || curso_id || tipo) { %> · <a href="/material">Limpiar filtros</a><% } %>
    </div>
  </div>
<% } %>
