<h3><i class="bi bi-envelope-plus"></i> Nuevo mensaje</h3>
<div class="card card-body">
  <p class="small text-muted">Elegí a quién enviar:</p>
  <div class="list-group">
    <% usuarios.forEach(u => { %>
      <a href="/mensajes/con/<%= u.id %>" class="list-group-item list-group-item-action d-flex justify-content-between">
        <span><i class="bi bi-person-circle"></i> <%= u.nombre %></span>
        <% if (u.rol === 'admin') { %><span class="badge badge-rol-admin">Admin</span>
        <% } else if (u.rol === 'profesor') { %><span class="badge badge-rol-profesor">Profesor</span>
        <% } else if (u.rol === 'soporte') { %><span class="badge badge-rol-soporte">Soporte</span>
        <% } else { %><span class="badge badge-rol-alumno">Alumno</span><% } %>
      </a>
    <% }) %>
  </div>
</div>
