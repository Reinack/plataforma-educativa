# Environment Variables for Plataforma Educativa
# Copiar este archivo a .env y completar los valores

# ── Servidor ──────────────────────────────────────────
PORT=3000
NODE_ENV=development   # producción: "production"

# ── Base de datos (Neon PostgreSQL) ───────────────────
# Obtener la connection string desde: https://console.neon.tech
# Formato: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ── Sesiones ──────────────────────────────────────────
SESSION_SECRET=cambia-este-valor-por-una-cadena-larga-y-aleatoria
